geo:Geometry a owl:Class ;
    rdfs:subClassOf geo:SpatialObject .

geo:SpatialObject a owl:Class .

fairyland:Site a owl:Class ;
    rdfs:label "Site"@en ;
    rdfs:comment "The overall excavation site that contains the trenches."@en ;
    rdfs:subClassOf geo:Feature .

fairyland:Street a owl:Class ;
    rdfs:label "Street / circulation route"@en ;
    rdfs:comment "A movement route through the outpost (e.g. the showroom path)."@en ;
    rdfs:subClassOf geo:Feature .

suni:29555707-7201-41b5-8ef4-1c59caac6f59 a owl:Class ;
    rdfs:subClassOf geo:Feature .

fairyland:Crater a owl:Class ;
    rdfs:label "Crater"@en ;
    rdfs:comment "An impact depression; folklore links them to the meteorite that closed the Cretaceous."@en ;
    rdfs:subClassOf fairyland:Find .

geo:Feature a owl:Class ;
    rdfs:subClassOf geo:SpatialObject .

fairyland:TimePeriod a owl:Class ;
    rdfs:label "Time period"@en ;
    rdfs:comment "A geological phase (Mesozoic) to which finds are attributed."@en .

fairyland:Kangaroo a owl:Class ;
    rdfs:label "Kangaroo"@en ;
    rdfs:comment "An out-of-place faunal find; cause of deposition unresolved."@en ;
    rdfs:subClassOf fairyland:Find .

fairyland:Pencil a owl:Class ;
    rdfs:label "Pencil stub"@en ;
    rdfs:comment "The short showroom pencil; a Jurassic recording instrument."@en ;
    rdfs:subClassOf fairyland:Find .

fairyland:Tealight a owl:Class ;
    rdfs:label "Tea light"@en ;
    rdfs:comment "A small IKEA-style candle; ubiquitous Cretaceous lighting fixture."@en ;
    rdfs:subClassOf fairyland:Find .

fairyland:FlatpackPanel a owl:Class ;
    rdfs:label "Flat-pack panel"@en ;
    rdfs:comment "A flat rectangular board, diagnostic of Jurassic (Early Flatpack) assembly."@en ;
    rdfs:subClassOf fairyland:Find .

fairyland:LingonberryJar a owl:Class ;
    rdfs:label "Lingonberry jar"@en ;
    rdfs:comment "A sealed preserve vessel; appears with the Cretaceous showroom economy."@en ;
    rdfs:subClassOf fairyland:Find .

fairyland:Stone a owl:Class ;
    rdfs:label "Stone"@en ;
    rdfs:comment "A natural or worked stone recorded during excavation."@en ;
    rdfs:subClassOf fairyland:Find .

