suni:fid a owl:DatatypeProperty ;
    rdfs:label "feature id"@en ;
    rdfs:domain suni:29555707-7201-41b5-8ef4-1c59caac6f59 ;
    rdfs:range xsd:integer .

<http://www.opengis.net/def/crs/EPSG/0/4326> a ns1:GeographicCRS,
        owl:NamedIndividual,
        prov:Entity ;
    rdfs:label "WGS 84"@en ;
    ns1:coordinateSystem <http://www.opengis.net/def/crs/EPSG/0/4326_cs> ;
    ns1:isApplicableTo <http://www.opengis.net/ont/crs/isbody/Earth> ;
    ns1:isBound false .

<http://www.opengis.net/ont/crs/EPSG:4326> a ns1:SpatialReferenceSystem ;
    ns1:asProj "+proj=longlat +datum=WGS84 +no_defs"^^ns1:proj4Literal ;
    ns1:asWKT "GEOGCS[\\\"WGS 84\\\",DATUM[\\\"WGS_1984\\\",SPHEROID[\\\"WGS 84\\\",6378137,298.257223563,AUTHORITY[\\\"EPSG\\\",\\\"7030\\\"]],AUTHORITY[\\\"EPSG\\\",\\\"6326\\\"]],PRIMEM[\\\"Greenwich\\\",0,AUTHORITY[\\\"EPSG\\\",\\\"8901\\\"]],UNIT[\\\"degree\\\",0.0174532925199433,AUTHORITY[\\\"EPSG\\\",\\\"9122\\\"]],AUTHORITY[\\\"EPSG\\\",\\\"4326\\\"]]"^^ns1:wktLiteral .

<http://www.opengis.net/ont/crs/cs/axis/east> a ns1:AxisDirection .

<http://www.opengis.net/ont/crs/cs/axis/north> a ns1:AxisDirection .

<http://www.opengis.net/ont/crs/geod/WGS84> a ns1:Ellipsoid ;
    rdfs:label "WGS 84"@en ;
    ns1:approximates <http://www.opengis.net/ont/crs/isbody/Earth> ;
    ns1:eccentricity 6.69438e-03 ;
    ns1:flatteningParameter 3.352811e-03 ;
    ns1:isSphere false ;
    ns1:semiMajorAxis "6378137.0"^^xsd:string ;
    ns1:semiMinorAxis "6356752.314245179"^^xsd:string ;
    skos:definition "+a=6378137 +f=0.0033528106647475126"^^xsd:string .

geo:asWKT a owl:DatatypeProperty .

geo:hasGeometry a owl:ObjectProperty .

fairyland: a owl:Ontology ;
    dct:creator "Research Squirrel Engineers Network" ;
    dct:description "A wholly fictional excavation dataset used to demonstrate the SPARQL Unicorn Ontology Documentation tool and the SPARQLing Unicorn QGIS plugin. The chronology is mapped onto the (real) Mesozoic geological periods for fun."@en ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> ;
    dct:title "FAIRyland — The Lost Flat-Pack Civilisation of Norrfors"@en ;
    rdfs:comment "Enriched edition: a schema (TBox) and a deep-time chronology were layered on top of the original SPARQLing-Unicorn export."@en .

fairyland:DenGulaVagen a fairyland:Street ;
    rdfs:label "Den gula vaegen (the yellow path)"@en ;
    suni:Name "Den gula vaegen (the yellow path)"^^xsd:string ;
    geo:hasGeometry fairyland:DenGulaVagen_geom ;
    rdfs:comment "Main E-W baulk path."@en .

fairyland:Returvagen a fairyland:Street ;
    rdfs:label "Returvaegen (return aisle)"@en ;
    suni:Name "Returvaegen (return aisle)"^^xsd:string ;
    geo:hasGeometry fairyland:Returvagen_geom ;
    rdfs:comment "Main N-S baulk path."@en .

fairyland:Smalgangen a fairyland:Street ;
    rdfs:label "Smaagaangen (narrow aisle)"@en ;
    suni:Name "Smaagaangen (narrow aisle)"^^xsd:string ;
    geo:hasGeometry fairyland:Smalgangen_geom ;
    rdfs:comment "Secondary E-W baulk path."@en .

fairyland:endMa a owl:DatatypeProperty ;
    rdfs:label "end (Ma)"@en ;
    rdfs:comment "Younger boundary of a period, in millions of years before present (smaller = younger)."@en ;
    rdfs:range xsd:decimal .

fairyland:hasperiod a owl:ObjectProperty ;
    rdfs:label "has period"@en ;
    rdfs:comment "Relates a find to the geological phase it is attributed to."@en ;
    rdfs:domain fairyland:Find ;
    rdfs:range fairyland:TimePeriod .

fairyland:hastrench a owl:ObjectProperty ;
    rdfs:label "has trench"@en ;
    rdfs:comment "Relates a find to the trench in which it was recorded."@en ;
    rdfs:domain fairyland:Find ;
    rdfs:range fairyland:Trench .

fairyland:startMa a owl:DatatypeProperty ;
    rdfs:label "start (Ma)"@en ;
    rdfs:comment "Older boundary of a period, in millions of years before present (larger = older)."@en ;
    rdfs:range xsd:decimal .

fairyland:withinSite a owl:ObjectProperty ;
    rdfs:label "within site"@en ;
    rdfs:comment "Relates a trench to the site it belongs to."@en ;
    rdfs:domain fairyland:Trench ;
    rdfs:range fairyland:Site .

