fairyland:Banana a owl:Class ;
    rdfs:label "Banana"@en ;
    rdfs:comment "Principal Minion fuel; deposits peak in the Cretaceous floruit."@en ;
    rdfs:subClassOf fairyland:Find .

fairyland:Triassic a fairyland:TimePeriod ;
    rdfs:label "Triassic - Pre-Flatpack"@en ;
    rdfs:comment "Earliest phase, 252-201 Ma: loose components and Allen keys dominate; no flat-pack panels yet."@en ;
    rdfs:seeAlso <https://en.wikipedia.org/wiki/Triassic> ;
    skos:broader fairyland:Mesozoic ;
    fairyland:endMa 201 ;
    fairyland:startMa 252 .

fairyland:Jurassic a fairyland:TimePeriod ;
    rdfs:label "Jurassic - Early Flatpack"@en ;
    rdfs:comment "Middle phase, 201-145 Ma: first flat-pack panels appear; meatball consumption rises."@en ;
    rdfs:seeAlso <https://en.wikipedia.org/wiki/Jurassic> ;
    skos:broader fairyland:Mesozoic ;
    fairyland:endMa 145 ;
    fairyland:startMa 201 .

fairyland:NorrforsOutpost a fairyland:Site ;
    rdfs:label "IkeaLand excavation areal (Norrfors Outpost)"@en ;
    geo:hasGeometry fairyland:NorrforsOutpost_geom ;
    rdfs:comment "The fictional excavation areal at Norrfors, laid out as a 6x5 grid of trenches."@en .

fairyland:Trench a owl:Class ;
    rdfs:label "Trench"@en ;
    rdfs:comment "An excavated area; finds are recorded as lying within a trench."@en ;
    rdfs:subClassOf geo:Feature .

fairyland:Cretaceous a fairyland:TimePeriod ;
    rdfs:label "Cretaceous - High Flatpack / Showroom floruit"@en ;
    rdfs:comment "Final phase, 145-66 Ma: streets laid out and banana caches peak; ended by the meteorite that left the Craters."@en ;
    rdfs:seeAlso <https://en.wikipedia.org/wiki/Cretaceous> ;
    skos:broader fairyland:Mesozoic ;
    fairyland:endMa 66 ;
    fairyland:startMa 145 .

fairyland:Minion a owl:Class ;
    rdfs:label "Minion"@en ;
    rdfs:comment "Remains of the small yellow workforce that operated the outpost."@en ;
    rdfs:subClassOf fairyland:Find .

sf:Polygon a owl:Class ;
    rdfs:subClassOf geo:Geometry .

fairyland:Koetbullar a owl:Class ;
    rdfs:label "Koettbullar (meatball find)"@en ;
    rdfs:comment "A spherical meatball artefact, the most abundant find class at the outpost."@en ;
    rdfs:subClassOf fairyland:Find .

fairyland:Mesozoic a fairyland:TimePeriod ;
    rdfs:label "Mesozoic (Age of the Flat-Pack Minions)"@en ;
    rdfs:comment "Umbrella era, 252-66 Ma. Default dating for the bulk of the original export (whose raw attribute reads 'Minion'). Comprises the Triassic, Jurassic and Cretaceous phases."@en ;
    rdfs:seeAlso <https://en.wikipedia.org/wiki/Mesozoic> ;
    skos:narrower fairyland:Cretaceous,
        fairyland:Jurassic,
        fairyland:Triassic ;
    fairyland:endMa 66 ;
    fairyland:startMa 252 .

