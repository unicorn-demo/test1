    ns1:unit_auth_code "EPSG"^^xsd:string ;
    ns1:unit_code "9122"^^xsd:string ;
    ns1:unit_conversion_factor 1.745329e-02 .

<http://www.opengis.net/ont/crs/cs/axis/Geodetic_longitude_degree_east> a ns1:CoordinateSystemAxis ;
